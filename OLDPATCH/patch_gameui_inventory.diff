                if human then
                    if tool.Parent == char then
                        -- Unequip
                        human:UnequipTools()
                        highlightSlot(nil)
                    else
                        -- Equip
                        human:EquipTool(tool)
                        highlightSlot(slotToEquip)
                    end
                end
            end
        end))

        refreshInventory()
    end

